                    { "value": "whatsapp", "label": "WhatsApp" },
                    { "value": "telegram", "label": "Telegram" },
                    { "value": "phone", "label": "Телефон" },
                    { "value": "none", "label": "Без CTA" }
                ] },
                { "key": "cta_url", "label": "URL CTA", "type": "text", "default": "" },
                { "key": "messenger_type", "label": "Тип мессенджера", "type": "select", "default": "none", "options": [
                    { "value": "none", "label": "Нет" },
                    { "value": "whatsapp", "label": "WhatsApp" },
                    { "value": "telegram", "label": "Telegram" }
                ] },
                { "key": "image", "label": "Изображение", "type": "text", "default": "" },
                { "key": "imageAlt", "label": "Alt", "type": "text", "default": "" },
                { "key": "availability", "label": "Наличие", "type": "select", "default": "available", "options": [
                    { "value": "available", "label": "Доступно" },
                    { "value": "limited", "label": "Ограничено" },
                    { "value": "on_request", "label": "По запросу" },
                    { "value": "hidden", "label": "Скрыто" }
                ] },
                { "key": "gallery", "label": "Галерея", "type": "textarea", "rows": 3, "default": "" }
            ]
        },
        { "key": "theme", "label": "Тема", "type": "select", "default": "light", "options": [
            { "value": "light", "label": "Светлая" },
            { "value": "alt", "label": "Мягкий фон" },
            { "value": "dark", "label": "Тёмная" }
        ] },
        { "key": "align", "label": "Выравнивание header", "type": "select", "default": "left", "options": [
            { "value": "left", "label": "Слева" },
            { "value": "center", "label": "По центру" }
        ] },
        { "key": "columns_desktop", "label": "Колонки desktop", "type": "number", "default": 3 },
        { "key": "columns_mobile", "label": "Колонки mobile", "type": "number", "default": 1 },
        { "key": "collection_mode", "label": "Режим длинного каталога", "type": "select", "default": "all", "options": [
            { "value": "all", "label": "Все карточки" },
            { "value": "load_more", "label": "Кнопка Показать ещё" },
            { "value": "pagination", "label": "Пагинация" }
        ] },
        { "key": "items_per_page", "label": "Карточек на шаг или страницу", "type": "number", "default": 6 },
        { "key": "show_results_count", "label": "Показывать счётчик результатов", "type": "boolean", "default": "1" },
        { "key": "show_search", "label": "Показывать поиск", "type": "boolean", "default": "1" },
        { "key": "show_category_filter", "label": "Показывать фильтр категорий", "type": "boolean", "default": "1" },
        { "key": "show_price_filter", "label": "Показывать фильтр цены", "type": "boolean", "default": "1" },
        { "key": "show_sort", "label": "Показывать сортировку", "type": "boolean", "default": "1" },
        { "key": "show_active_filters", "label": "Показывать активные фильтры", "type": "boolean", "default": "1" },
        { "key": "search_in_title", "label": "Искать по заголовку", "type": "boolean", "default": "1" },
        { "key": "search_in_excerpt", "label": "Искать по описанию", "type": "boolean", "default": "1" },
        { "key": "search_in_category", "label": "Искать по категории", "type": "boolean", "default": "1" },
        { "key": "search_in_badge", "label": "Искать по badge", "type": "boolean", "default": "1" },
        { "key": "search_in_tags", "label": "Искать по тегам", "type": "boolean", "default": "1" },
        { "key": "search_in_price", "label": "Искать по цене", "type": "boolean", "default": "0" },
        { "key": "search_in_availability", "label": "Искать по наличию", "type": "boolean", "default": "1" },
        { "key": "show_image", "label": "Показывать изображение", "type": "boolean", "default": "1" },
        { "key": "show_category", "label": "Показывать категорию", "type": "boolean", "default": "1" },
        { "key": "show_badge", "label": "Показывать badge", "type": "boolean", "default": "1" },
        { "key": "show_price", "label": "Показывать цену", "type": "boolean", "default": "1" },
        { "key": "show_old_price", "label": "Показывать старую цену", "type": "boolean", "default": "1" },
        { "key": "show_excerpt", "label": "Показывать описание", "type": "boolean", "default": "1" },
        { "key": "show_cta", "label": "Показывать CTA", "type": "boolean", "default": "1" }
    ]
}